  "keyFeatures": [
    "Ephemeral messaging with zero database persistence",
    "Optional end-to-end AES-GCM 256-bit encryption",
    "Public and private room support with visibility controls",
    "Real-time presence tracking and typing indicators",
    "Vote kick and moderation tools for room creators",
    "Message reactions, reply threads, and read receipts",
    "Room themes, tags, TTL, and capacity controls",
    "Swipe-to-reply mobile gestures",
    "PWA support with offline fallback",
    "Security hardened with flood detection and rate limiting"
  ],
  "publicApiSurface": [
    "useChatRoom - Core realtime hook with broadcast, presence, E2EE, reactions, vote kick, TTL, succession, AFK, read receipts",
    "useLobby - Public room discovery via lobby presence",
    "useBookmarks - Room bookmark management",
    "useKeyboardShortcuts - Keyboard shortcut handler",
    "useSwipeGesture - Touch swipe detection for mobile",
    "encryptMessage / decryptMessage - AES-GCM E2EE functions",
    "applyRoomTheme - Theme system with 25+ CSS properties",
    "filterContent - Opt-in profanity filter with 3 levels",
    "RateLimiter - In-memory rate limiting for flood protection"
  ]
